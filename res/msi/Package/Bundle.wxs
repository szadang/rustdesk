<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
     <?include Includes.wxi?>
    <Bundle Name="$(var.Product) Setup"
            Version="$(var.Version)"
            Manufacturer="$(var.Manufacturer)"
            UpgradeCode="$(var.UpgradeCode)"
            IconSourceFile="Resources\icon.ico">

        <Variable Name="INSTALLFOLDER_INNER" Type="string" Value="RustDesk" />
		<BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.HyperlinkLicense" />

        <Chain>
            <MsiPackage Id="RustDeskMsi"
                        SourceFile="SignOutput\rustdesk-$(var.Version)-x86_64.msi"
                        Compressed="yes"
                        Vital="yes">
                <MsiProperty Name="INSTALLFOLDER_INNER" Value="[INSTALLFOLDER_INNER]" />
            </MsiPackage>
        </Chain>
    </Bundle>
</Wix>